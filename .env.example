# AI Model Kontrol Configuration
# Copy this file to .env and fill in your values

# HuggingFace API Token (optional, increases rate limits)
# Get your token from: https://huggingface.co/settings/tokens
# Token type: Read-only
AIMODEL_HF_TOKEN=your_huggingface_token_here

# HuggingFace Search Settings
AIMODEL_HF_SEARCH_LIMIT=15          # Results per page
AIMODEL_HF_SEARCH_MAX_PAGES=10      # Maximum pages to fetch

# Ollama Settings
AIMODEL_OLLAMA_API_BASE=http://localhost:11434
AIMODEL_OLLAMA_TIMEOUT=5

# Cache Settings
AIMODEL_SEARCH_CACHE_TTL_SECONDS=90
AIMODEL_SEARCH_CACHE_MAX_ENTRIES=20
